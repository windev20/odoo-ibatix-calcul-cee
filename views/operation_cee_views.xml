<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_operation_cee_form_calcul" model="ir.ui.view">
        <field name="name">ibatix.operation.cee.form.calcul</field>
        <field name="model">ibatix.operation.cee</field>
        <field name="inherit_id" ref="objets_ibatix.view_operation_cee_form"/>
        <field name="arch" type="xml">

            <!-- Barre de statut + boutons d'action IA -->
            <xpath expr="//sheet" position="before">
                <header>
                    <button name="action_reanalyser_fiche"
                            type="object"
                            string="Réanalyser avec l'IA"
                            class="btn btn-primary"
                            invisible="not fiche_pdf"/>
                    <button name="action_reinitialiser_analyse"
                            type="object"
                            string="Réinitialiser l'analyse"
                            class="btn btn-warning"
                            invisible="not formule_analysee"/>
                    <field name="formule_analysee" invisible="1"/>
                    <span class="badge rounded-pill text-bg-success ms-2"
                          invisible="not formule_analysee">Fiche analysee</span>
                    <span class="badge rounded-pill text-bg-secondary ms-2"
                          invisible="formule_analysee">En attente d'analyse</span>
                </header>
            </xpath>

            <!-- Alertes -->
            <xpath expr="//sheet/group" position="before">
                <div class="alert alert-warning mb-3"
                     invisible="formule_analysee or not fiche_pdf">
                    <strong>Ce PDF n'a pas encore ete analyse.</strong>
                    Cliquez sur Reanalyser avec l'IA pour generer la formule et le guide technique.
                </div>
                <div class="alert alert-success mb-3"
                     invisible="not formule_analysee">
                    <strong>Analyse IA a jour.</strong>
                    Champs requis :
                    <field name="champs_requis" readonly="1" nolabel="1" class="d-inline fw-bold"/>
                    -- <field name="formule_description" readonly="1" nolabel="1" class="d-inline text-muted"/>
                </div>
            </xpath>

            <!-- Onglets MPR + Guide + Formule en un seul notebook -->
            <xpath expr="//sheet/group" position="after">
                <notebook>
                    <page string="Sous-traitance" name="sous_traitance_config">
                        <group>
                            <field name="sous_traitant_defaut_id"/>
                        </group>
                    </page>
                    <page string="MaPrimeRenov'" name="mpr_config">
                        <group>
                            <field name="eligible_mpr"/>
                            <field name="type_calcul_mpr" invisible="not eligible_mpr"/>
                            <field name="plafond_depense_mpr" invisible="not eligible_mpr"/>
                        </group>
                        <group string="Baremes MPR (bleu / jaune / violet)" invisible="not eligible_mpr">
                            <field name="prime_mpr_bleu" string="Tres modestes (bleu)"/>
                            <field name="prime_mpr_jaune" string="Modestes (jaune)"/>
                            <field name="prime_mpr_violet" string="Intermediaires (violet)"/>
                        </group>
                    </page>
                    <page string="Guide technique" name="guide_ia" invisible="not formule_analysee">
                        <field name="guide_html" widget="html" readonly="1" nolabel="1"/>
                    </page>
                    <page string="Formule Cumac" name="formule_ia" invisible="not formule_analysee">
                        <group>
                            <field name="champs_requis"/>
                            <field name="formule_description"/>
                        </group>
                        <field name="formule_cumac_python" widget="text" readonly="1" nolabel="1"/>
                    </page>
                </notebook>
            </xpath>

        </field>
    </record>

</odoo>
