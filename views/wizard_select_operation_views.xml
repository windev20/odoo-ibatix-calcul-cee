<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_wizard_select_operation_cee_form" model="ir.ui.view">
        <field name="name">ibatix.wizard.select.operation.cee.form</field>
        <field name="model">ibatix.wizard.select.operation.cee</field>
        <field name="arch" type="xml">
            <form string="Ajouter une opération CEE">
                <group>
                    <field name="operation_cee_id"
                           options="{'no_create': True}"
                           placeholder="Tapez BAR-TH, BAR-EN, RES-CH…"/>
                </group>
                <footer>
                    <button name="action_confirmer" type="object" string="Ajouter" class="btn-primary"/>
                    <button special="cancel" string="Annuler"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
