<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_wizard_cee_form" model="ir.ui.view">
        <field name="name">ibatix.wizard.cee.form</field>
        <field name="model">ibatix.wizard.cee</field>
        <field name="arch" type="xml">
            <form string="Calcul de la prime CEE">
                <field name="sale_line_id" invisible="1"/>
                <field name="fiche_analysee" invisible="1"/>
                <field name="champs_requis" invisible="1"/>
                <field name="formule_cumac_python" invisible="1"/>

                <!-- Bandeau de contexte -->
                <group string="Contexte du devis" col="4">
                    <field name="operation_cee_id" readonly="1"/>
                    <field name="nom_client" readonly="1"/>
                    <field name="delegataire_id" readonly="1"/>
                    <field name="contrat_id" readonly="1"/>
                    <field name="categorie_precarite" readonly="1"/>
                </group>

                <!-- Formule utilisée -->
                <div class="alert alert-info mb-0 py-1"
                     invisible="not formule_cumac_python">
                    <small>
                        <strong>Formule :</strong>
                        <field name="formule_description" nolabel="1" readonly="1" class="d-inline"/>
                    </small>
                </div>

                <notebook>

                    <!-- Onglet 1 : Guide technique -->
                    <page string="Guide technique" name="guide">
                        <div class="alert alert-warning mb-3" invisible="fiche_analysee">
                            <p class="mb-2">
                                <strong>Analysez la fiche de l'opération</strong> pour obtenir
                                les informations techniques à collecter et activer le calcul automatique du cumac.
                            </p>
                            <button name="action_analyser_fiche"
                                    type="object"
                                    string="Analyser la fiche CEE avec l'IA"
                                    class="btn btn-warning"/>
                        </div>
                        <field name="guide_technique"
                               widget="html"
                               invisible="not fiche_analysee"
                               readonly="1"
                               nolabel="1"/>
                    </page>

                    <!-- Onglet 2 : Paramètres techniques -->
                    <page string="Informations techniques" name="params">
                        <field name="product_line_id" invisible="1"/>
                        <div class="alert alert-warning"
                             invisible="not champs_manquants_produit">
                            <div class="d-flex align-items-start gap-2">
                                <i class="fa fa-exclamation-triangle mt-1"/>
                                <div>
                                    <strong>Données manquantes dans le descriptif produit :</strong><br/>
                                    <field name="champs_manquants_produit" nolabel="1" readonly="1"/>
                                    <br/>
                                    <small>Complétez le descriptif du produit, puis rouvrez la calculatrice.</small>
                                </div>
                                <button name="action_ouvrir_produit"
                                        type="object"
                                        string="Ouvrir la fiche produit"
                                        class="btn btn-sm btn-warning ms-auto"
                                        invisible="not product_line_id"/>
                            </div>
                        </div>
                        <group string="Identification du produit" col="2">
                            <field name="marque"/>
                            <field name="modele"/>
                        </group>
                        <group string="Caractéristiques" col="2">
                            <field name="surface_m2"
                                   invisible="champs_requis and 'surface_m2' not in (champs_requis or '')"/>
                            <field name="surface_chauffee"
                                   invisible="champs_requis and 'surface_chauffee' not in (champs_requis or '')"/>
                            <field name="resistance_thermique"
                                   invisible="champs_requis and 'resistance_thermique' not in (champs_requis or '')"/>
                            <field name="puissance_kw"
                                   invisible="champs_requis and 'puissance_kw' not in (champs_requis or '')"/>
                            <field name="cop"
                                   invisible="champs_requis and 'cop' not in (champs_requis or '')"/>
                            <field name="scop"
                                   invisible="champs_requis and 'scop' not in (champs_requis or '')"/>
                            <field name="etas"
                                   invisible="champs_requis and 'etas' not in (champs_requis or '')"/>
                            <field name="nb_logements"
                                   invisible="champs_requis and 'nb_logements' not in (champs_requis or '')"/>
                            <field name="type_logement"
                                   invisible="champs_requis and 'type_logement' not in (champs_requis or '')"/>
                            <field name="zone_climatique"
                                   invisible="champs_requis and 'zone_climatique' not in (champs_requis or '') and 'facteur_zone' not in (champs_requis or '')"/>
                            <field name="profil_soutirage"
                                   invisible="champs_requis and 'profil_soutirage' not in (champs_requis or '')"/>
                            <field name="efficacite_energetique"
                                   invisible="champs_requis and 'efficacite_energetique' not in (champs_requis or '')"/>
                            <field name="type_energie"
                                   invisible="champs_requis and 'type_energie' not in (champs_requis or '')"/>
                        </group>
                        <group string="Pompe à chaleur (BAR-TH-171)" col="2"
                               invisible="champs_requis and 'classe_regulateur' not in (champs_requis or '')">
                            <field name="type_application_pac"/>
                            <field name="usage_pac"/>
                            <field name="classe_regulateur"/>
                        </group>
                        <group string="Régulation pièce par pièce (BAR-TH-173)" col="2"
                               invisible="champs_requis and 'classe_regulation_iso52120' not in (champs_requis or '')">
                            <field name="classe_regulation_iso52120"/>
                        </group>
                        <group string="Notes" col="1">
                            <field name="notes_techniques" nolabel="1"/>
                        </group>
                    </page>

                    <!-- Onglet 3 : Calcul -->
                    <page string="Calcul de la prime" name="calcul">
                        <group string="Valorisation" col="2">
                            <field name="cumac_cee"/>
                            <field name="valo_cee"/>
                        </group>
                        <group>
                            <div class="alert alert-success">
                                <h4 class="mb-0">
                                    Prime CEE calculée :
                                    <field name="prime_cee"
                                           class="fs-4 fw-bold"
                                           nolabel="1"
                                           readonly="1"/>
                                    €
                                </h4>
                                <small class="text-muted">
                                    = <field name="cumac_cee" nolabel="1" readonly="1"/> MWhc
                                    × <field name="valo_cee" nolabel="1" readonly="1"/> €/MWhc
                                </small>
                            </div>
                            <field name="prime_mpr_eligible" invisible="1"/>
                            <field name="prime_mpr_ecrete_preview" invisible="1"/>
                            <!-- MPR eligible + prime > 0 -->
                            <div class="alert alert-primary"
                                 invisible="not prime_mpr_eligible or not prime_mpr_preview">
                                <h4 class="mb-1">
                                    MaPrimeRénov’ estimée :
                                    <field name="prime_mpr_preview"
                                           class="fs-4 fw-bold"
                                           nolabel="1"
                                           readonly="1"/>
                                    €
                                    <span invisible="not prime_mpr_ecrete_preview"
                                          class="badge bg-warning text-dark ms-2 fs-6">
                                        Écrêté
                                    </span>
                                </h4>
                                <small class="text-muted">
                                    <field name="prime_mpr_explication" nolabel="1" readonly="1"/>
                                </small>
                            </div>
                            <!-- MPR eligible mais prime = 0 (ecretement total) -->
                            <div class="alert alert-warning"
                                 invisible="not prime_mpr_eligible or prime_mpr_preview">
                                <strong>MaPrimeRénov’ : 0 €</strong>
                                <br/>
                                <small>
                                    <field name="prime_mpr_explication" nolabel="1" readonly="1"/>
                                </small>
                            </div>
                            <!-- Non eligible -->
                            <div class="alert alert-secondary" invisible="prime_mpr_eligible">
                                <small class="text-muted">
                                    <field name="prime_mpr_explication" nolabel="1" readonly="1"/>
                                </small>
                            </div>
                        </group>
                    </page>

                </notebook>

                <footer>
                    <button name="action_confirmer"
                            string="Enregistrer la prime sur le devis"
                            type="object"
                            class="btn btn-primary"/>
                    <button string="Annuler"
                            class="btn btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
