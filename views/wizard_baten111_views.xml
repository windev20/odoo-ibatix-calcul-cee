<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_wizard_baten111_form" model="ir.ui.view">
        <field name="name">ibatix.wizard.baten111.form</field>
        <field name="model">ibatix.wizard.baten111</field>
        <field name="arch" type="xml">
            <form string="Paramètres BAT-EN-111">
                <field name="order_id" invisible="1"/>
                <field name="product_id" invisible="1"/>
                <field name="line_id" invisible="1"/>
                <div class="alert alert-info mb-3">
                    <strong>Fenêtre pariétodynamique (BAT-EN-111)</strong><br/>
                    Veuillez renseigner les paramètres du bâtiment nécessaires au calcul de la prime CEE.
                </div>
                <group>
                    <field name="secteur_activite" autofocus="1"/>
                    <field name="type_vmc"/>
                </group>
                <footer>
                    <button name="action_confirm"
                            string="Valider"
                            type="object"
                            class="btn-primary"/>
                    <button string="Annuler" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
