<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_wizard_cee_simple_form" model="ir.ui.view">
        <field name="name">ibatix.wizard.cee.simple.form</field>
        <field name="model">ibatix.wizard.cee.simple</field>
        <field name="arch" type="xml">
            <form string="Paramètres de l'opération CEE">
                <field name="line_id" invisible="1"/>
                <div class="alert alert-info mb-3" role="alert">
                    <strong><field name="operation_name" readonly="1"/></strong><br/>
                    Veuillez renseigner les paramètres nécessaires au calcul de la prime CEE.
                </div>
                <group>
                    <field name="surface_chauffee" autofocus="1"/>
                    <field name="type_logement" widget="radio"/>
                    <field name="type_energie" widget="radio"/>
                </group>
                <footer>
                    <button name="action_confirmer" type="object"
                            string="Valider" class="btn-primary"/>
                    <button special="cancel" string="Annuler" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
