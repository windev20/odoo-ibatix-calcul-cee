<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_sale_sous_traitant"
              inherit_id="sale.report_saleorder_document">

        <!-- Pré-calcul de la map sous-traitant avant le tableau principal -->
        <xpath expr="//table[hasclass('o_main_table')]" position="before">
            <t t-set="subcontractor_map" t-value="doc._get_report_subcontractor_map()"/>
        </xpath>

        <!-- Injection du bloc sous-traitant après chaque ligne produit -->
        <xpath expr="//tr[@name='tr_product']" position="after">
            <t t-if="subcontractor_map and line.id in subcontractor_map">
                <t t-set="st_block" t-value="subcontractor_map[line.id]"/>
                <t t-set="st" t-value="st_block['installateur']"/>
                <t t-set="st_qualifs" t-value="st_block['qualifications']"/>
                <tr name="tr_sous_traitant" style="background: transparent;">
                    <td colspan="99" style="padding: 4px 0 10px 0; border: none;">
                        <div style="padding: 8px 12px; background-color: #f2f2f2; border-left: 3px solid #2c6fad; margin-top: 4px;">
                            <div style="font-size: 7pt; font-weight: bold; color: #2c6fad; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 3px;">
                                Sous-traitant pour cette opération
                            </div>
                            <div style="font-size: 9pt; font-weight: bold; color: #1a1a1a;">
                                <t t-esc="st.name"/>
                            </div>
                            <t t-if="st.street or st.zip or st.city">
                                <div style="font-size: 8pt; color: #444; margin-top: 1px;">
                                    <t t-if="st.street"><t t-esc="st.street"/><t t-if="st.zip or st.city">, </t></t>
                                    <t t-esc="((st.zip or '') + ' ' + (st.city or '')).strip()"/>
                                </div>
                            </t>
                            <t t-if="st.phone or st.email">
                                <div style="font-size: 8pt; color: #444; margin-top: 1px;">
                                    <t t-if="st.phone"><t t-esc="st.phone"/></t>
                                    <t t-if="st.phone and st.email"><span style="color: #aaa;"> · </span></t>
                                    <t t-if="st.email"><t t-esc="st.email"/></t>
                                </div>
                            </t>
                            <t t-if="st_qualifs">
                                <div style="margin-top: 5px; font-size: 8pt;">
                                    <span style="color: #2c6fad; font-weight: bold;">Qualifications RGE en cours :</span>
                                    <t t-foreach="st_qualifs" t-as="q">
                                        <div style="margin: 2px 0 0 8px; color: #333; font-size: 8pt;">
                                            <span style="color: #2c6fad;">&#x25CF;</span>
                                            <span style="font-weight: bold;"> <t t-esc="q.numero_rge or '—'"/></span>
                                            <t t-if="q.start_date or q.end_date">
                                                <span style="color: #888;">
                                                    <t t-if="q.start_date"> — du <t t-esc="q.start_date" t-options="{'widget': 'date'}"/></t>
                                                    <t t-if="q.end_date"> au <t t-esc="q.end_date" t-options="{'widget': 'date'}"/></t>
                                                </span>
                                            </t>
                                            <t t-if="q.public_url">
                                                <span style="color: #888;"> — </span>
                                                <a t-att-href="q.public_url" style="color: #2c6fad;">Voir le certificat</a>
                                            </t>
                                        </div>
                                    </t>
                                </div>
                            </t>
                        </div>
                    </td>
                </tr>
            </t>
        </xpath>

    </template>

</odoo>
